<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CityEdit.ViewModels"
             xmlns:items="using:CityEdit.ViewModels.Items"
             xmlns:conv="using:CityEdit.Converters"
             x:Class="CityEdit.Views.SurfersView"
             x:DataType="vm:MainWindowViewModel">

    <UserControl.Resources>
        <conv:HalfWidthConverter x:Key="HalfWidth" Margin="6"/>
        <conv:SkinWidthConverter x:Key="SkinWidth" Margin="6"/>
    </UserControl.Resources>

    <DockPanel>
        <!-- Верхняя панель с заголовком и действиями -->
        <Border DockPanel.Dock="Top" Margin="0,0,0,16">
            <StackPanel Spacing="8">
                <TextBlock Classes="heading" Text="SURFERS" VerticalAlignment="Center"/>
                <WrapPanel Orientation="Horizontal">
                    <Button Content="UNLOCK ALL" FontSize="10"
                            Command="{Binding UnlockAllSurfersCommand}" Padding="12,6" Margin="0,0,4,4"/>
                    <Button Content="LOCK ALL" FontSize="10"
                            Command="{Binding LockAllSurfersCommand}" Padding="12,6" Margin="0,0,4,4"/>
                    <Button Content="MAX LEVEL" FontSize="10"
                            Command="{Binding MaxLevelAllSurfersCommand}" Padding="12,6" Margin="0,0,4,4"/>
                    <Button Content="UNLOCK SKINS" FontSize="10"
                            Command="{Binding UnlockAllSkinsCommand}" Padding="12,6" Margin="0,0,4,4"/>
                    <Button Content="LOCK SKINS" FontSize="10"
                            Command="{Binding LockAllSkinsCommand}" Padding="12,6" Margin="0,0,4,4"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Список серферов -->
        <ItemsControl ItemsSource="{Binding Surfers}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="items:SurferItemViewModel">
                    <Border Classes="card" Margin="0,0,0,8">
                        <StackPanel Spacing="8">
                            <!-- Имя серфера — сверху по центру -->
                            <TextBlock Text="{Binding DisplayName}"
                                       FontWeight="Bold" FontSize="14"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextTrimming="None"
                                       TextWrapping="Wrap"/>

                            <!-- Управление: unlock + lvl + score — адаптивная сетка -->
                            <Grid ColumnDefinitions="*,*,*">
                                <!-- Разблокировка -->
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8" VerticalAlignment="Center"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="UNLOCKED" FontSize="10"
                                               Foreground="#808080" VerticalAlignment="Center"/>
                                    <ToggleSwitch IsChecked="{Binding IsUnlocked}"
                                                  MinWidth="40"/>
                                </StackPanel>

                                <!-- Уровень -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal"
                                            Spacing="4" VerticalAlignment="Center"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="LVL" FontSize="10"
                                               Foreground="#808080" VerticalAlignment="Center"/>
                                    <NumericUpDown Value="{Binding Level}"
                                                   Minimum="1" Maximum="20"
                                                   MinWidth="90" FontSize="13"
                                                   HorizontalAlignment="Stretch"/>
                                </StackPanel>

                                <!-- Рекорд -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal"
                                            Spacing="4" VerticalAlignment="Center"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="SCORE" FontSize="10"
                                               Foreground="#808080" VerticalAlignment="Center"/>
                                    <NumericUpDown Value="{Binding HighScore}"
                                                   Minimum="0" Maximum="999999999"
                                                   MinWidth="110" FontSize="13"
                                                   HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Grid>

                            <!-- Скины серфера — WrapPanel с адаптивной шириной -->
                            <ItemsControl ItemsSource="{Binding Skins}"
                                          IsVisible="{Binding Skins.Count}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="items:SkinItemViewModel">
                                        <Border Background="#1E1E1E" CornerRadius="3"
                                                Padding="8,6" Margin="2"
                                                BorderBrush="#2A2A2A" BorderThickness="1"
                                                Cursor="Hand">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource SkinWidth}">
                                                    <Binding Path="Bounds.Width" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                    <Binding Path="IsLastInOddRow"/>
                                                </MultiBinding>
                                            </Border.Width>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <CheckBox IsChecked="{Binding IsUnlocked}"
                                                          MinWidth="0" Padding="0"
                                                          VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontSize="11"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="None"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </DockPanel>
</UserControl>
